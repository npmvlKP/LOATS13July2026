# LOATS13July2026 Configuration

# OpenAlgo API Configuration
OPENALGO_API_KEY=your_openalgo_api_key_here
OPENALGO_BASE_URL=https://api.openalgo.in/v1

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_ADMIN_IDS=["123456789"]  # Comma-separated list of authorized admin user IDs

# Trading Configuration
DEFAULT_SYMBOL=NIFTY
DEFAULT_TIMEFRAME=1min
SENTIMENT_THRESHOLD=0.05

# Database Configuration
SQLITE_DB_PATH=data/loats.db
AUDIT_LOG_PATH=data/audit.log
RETENTION_DAYS=2555  # 7 years

# Scheduler Configuration
TA_SCAN_INTERVAL=60  # 1 minute
SENTIMENT_SCAN_INTERVAL=300  # 5 minutes
SIGNAL_SCAN_INTERVAL=30  # 30 seconds
