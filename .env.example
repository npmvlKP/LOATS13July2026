# LOATS13July2026 Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Environment Configuration
# =============================================================================
ENVIRONMENT=development  # development, production, test

# =============================================================================
# OpenAlgo API Configuration
# =============================================================================
# REQUIRED: OpenAlgo API key (no default - must be set explicitly)
OPENALGO_API_KEY=your_openalgo_api_key_here
OPENALGO_BASE_URL=http://127.0.0.1:5000
OPENALGO_MODE=ANALYZE  # ANALYZE or LIVE

# =============================================================================
# Telegram Bot Configuration
# =============================================================================
# REQUIRED: Telegram bot token for alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_ADMIN_IDS=["123456789"]  # List of authorized admin user IDs

# =============================================================================
# Default Trading Parameters
# =============================================================================
DEFAULT_SYMBOL=NIFTY
DEFAULT_TIMEFRAME=1min
SENTIMENT_THRESHOLD=0.05
REQUEST_TIMEOUT=30.0  # HTTP request timeout (seconds)

# =============================================================================
# Database Configuration
# =============================================================================
SQLITE_DB_PATH=data/loats.db
AUDIT_LOG_PATH=data/audit.log
RETENTION_DAYS=2555  # 7 years

# =============================================================================
# Scheduler Configuration
# =============================================================================
TA_SCAN_INTERVAL=60  # Technical analysis scan interval (seconds)
SENTIMENT_SCAN_INTERVAL=300  # Sentiment analysis scan interval (seconds)
SIGNAL_SCAN_INTERVAL=30  # Signal scan interval (seconds)

# =============================================================================
# Trading Configuration
# =============================================================================
NIFTY_LOT_SIZE=25
MAX_ORDER_VALUE=200000.00
MAX_DAILY_ORDERS=500
MAX_OPS=3  # Maximum orders per second
CIRCUIT_LIMIT_PCT=0.05

# =============================================================================
# Risk Management
# =============================================================================
MAX_POSITION_PER_SYMBOL=1000
MAX_TOTAL_EXPOSURE=1000000.00

# =============================================================================
# NVIDIA NIM Rate Limiting
# =============================================================================
NIM_MAX_REQUESTS_PER_MINUTE=20
NIM_MIN_GAP_SECONDS=3.0
NIM_MAX_CONTEXT_TOKENS=4096

# =============================================================================
# Timezone Configuration
# =============================================================================
TIMEZONE=Asia/Kolkata  # All datetime operations use this timezone